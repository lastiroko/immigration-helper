# Helfa frontend env vars
#
# Copy to .env.local for local dev (.env.local is gitignored).
# Production values are set in the Vercel dashboard.
# .env.development and .env.production also exist with defaults Vite
# auto-loads per mode — only set values here you want to override.

# Pre-pivot CRM API base URL (Spring Boot backend on Railway).
# Only used by the legacy /login, /dashboard-legacy, /tasks, /marketplace,
# /offices routes. NOT used by /anmeldung-koeln or
# /auslaenderbehoerde-koeln — they're backend-free.
#
# Development (local Spring Boot):  http://localhost:8080/api/v1
# Production:                       https://immigration-helper-production.up.railway.app/api/v1
VITE_API_URL=http://localhost:8080/api/v1

# Stripe public key — only used by the legacy billing flow. Never
# commit a secret key here; the secret lives only on the backend.
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_…
